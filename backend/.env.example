# ── App ──────────────────────────────────────────────
APP_ENV=development
APP_HOST=0.0.0.0
APP_PORT=8000
DEBUG=true
CORS_ORIGINS=["http://localhost:3000"]

# ── PostgreSQL (Neon DB) ────────────────────────────
# Production: use Neon's *pooled* endpoint with asyncpg-compatible SSL param.
# Format: postgresql+asyncpg://user:password@ep-xxx-pooler.region.aws.neon.tech/extractify?ssl=require
# Direct (non-pooler) endpoint is only needed for one-off admin tasks.
# Local dev (Docker): postgresql+asyncpg://postgres:postgres@localhost:5432/extractify
DATABASE_URL=postgresql+asyncpg://postgres:postgres@localhost:5432/extractify
DATABASE_POOL_SIZE=5
DATABASE_MAX_OVERFLOW=10
DATABASE_CONNECT_RETRIES=5
DATABASE_CONNECT_RETRY_SECONDS=2
# AUTO_CREATE_TABLES=true   # default in development; set false when using Alembic only

# ── Rate Limiting ───────────────────────────────────
RATE_LIMIT_PER_MINUTE=30

# ── Instagram Authentication ───────────────────
# Required for downloading Stories, Photos, and authenticated content.
# Get these from your browser: DevTools (F12) → Application → Cookies → instagram.com
# INSTAGRAM_SESSION_ID=your_sessionid_cookie_value
# INSTAGRAM_CSRF_TOKEN=your_csrftoken_cookie_value
# INSTAGRAM_DS_USER_ID=your_ds_user_id_cookie_value
# INSTAGRAM_COOKIES_FILE=instagram_cookies.txt

# ── Facebook Authentication ─────────────────────
# Required for downloading Stories, Photos, and authenticated content.
# Get these from your browser: DevTools (F12) → Application → Cookies → facebook.com
# FACEBOOK_C_USER=your_c_user_cookie_value
# FACEBOOK_XS=your_xs_cookie_value
# FACEBOOK_COOKIES_FILE=facebook_cookies.txt

# ── Twitter / X Authentication ──────────────────
# Required for downloading videos, GIFs, and photos from tweets.
# Get these from your browser: DevTools (F12) → Application → Cookies → x.com
# TWITTER_AUTH_TOKEN=your_auth_token_cookie_value
# TWITTER_CSRF_TOKEN=your_ct0_cookie_value
# TWITTER_COOKIES_FILE=twitter_cookies.txt
# Override the default public bearer token if it gets revoked:
# TWITTER_BEARER_TOKEN=

# ── Threads Authentication ───────────────────
# THREADS_COOKIES_FILE=threads_cookies.txt
# Override GraphQL doc IDs if Meta rotates them:
# THREADS_POST_DOC_ID=26399684949649381
# THREADS_USER_DOC_ID=23904112853711550
# THREADS_APP_ID=238260118697367

# ── Instagram API identifiers ────────────────
# Override if the public IDs are rotated:
# IG_APP_ID=936619743392459
# IG_MOBILE_APP_ID=567067343352427
# IG_GRAPHQL_POST_HASH=b3055c01b4b222b8a47dc12b090e4e64

# ── Tumblr API ───────────────────────────────
# Comma-separated read-only consumer keys for Tumblr v2 API:
# TUMBLR_API_KEYS=key1,key2
